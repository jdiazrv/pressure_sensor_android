<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#07111B"
                android:startColor="#0F2336" />
        </shape>
    </item>

    <item
        android:width="140dp"
        android:height="140dp"
        android:gravity="center">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:endColor="#53C6FF"
                android:startColor="#1A3C57" />
        </shape>
    </item>

    <item
        android:width="54dp"
        android:height="54dp"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>
